# Coop daemon environment — copy to /etc/coop/coop.env and edit.
# Every value is optional except the address; uncomment what you need.

# Bind address. Keep 127.0.0.1 for local-only; use 0.0.0.0 for LAN/public.
COOP_ADDR=127.0.0.1:9700

# Data directory (the systemd unit sets this to /var/lib/coop automatically).
#COOP_DATA_DIR=/var/lib/coop

# --- Required before exposing beyond loopback -------------------------------
# Bearer token for the API + Farm UI. Generate once: openssl rand -hex 32
#COOP_API_TOKEN=

# Allow non-loopback Host/Origin headers (needed when COOP_ADDR isn't loopback).
#COOP_PUBLIC=1

# --- Optional ---------------------------------------------------------------
# Auto-unlock a sealed BYOK vault at startup.
#COOP_VAULT=/var/lib/coop/vault.json
#COOP_PASSPHRASE=change-me

# Login throttle: failed attempts per IP per 60s before HTTP 429 (default 10).
#COOP_LOGIN_MAX_ATTEMPTS=10

# Max job/task prompt size in bytes (default 262144; 0 disables).
#COOP_MAX_PROMPT_BYTES=262144

# Logging filter.
#COOP_LOG=info
